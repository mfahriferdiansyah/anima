# Copy to .env.local and fill in. Vite inlines VITE_* at BUILD time, so after
# changing these you must rebuild (pnpm build) or restart the dev server
# (pnpm dev) for the new values to take effect. A plain page refresh is not
# enough when running the built bundle (pnpm preview).

# Base URL of the stateless Go backend (auth + chat SSE + distill + presence relay).
# Dev default below; the backend's ALLOWED_ORIGINS must list the SPA origin.
VITE_BACKEND_URL=http://localhost:8080

# Walrus aggregator the chromeless reader (reader.html) fetches published share
# blobs from. Optional: falls back to the testnet aggregator when unset.
VITE_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# Google OAuth 2.0 Web client ID for the read-only Calendar integration. When
# unset, the Calendar shows "not configured" (it never crashes). To enable it:
#   1. Google Cloud Console: create a project, enable the Google Calendar API.
#   2. OAuth consent screen: type External, add yourself as a test user.
#   3. Credentials -> Create OAuth client ID -> Web application.
#      Authorized JavaScript origins: the SPA origin, e.g. http://localhost:5173
#   4. Paste the client id (xxx.apps.googleusercontent.com) below.
# The access token is held in the browser only and never reaches the backend.
VITE_GOOGLE_CLIENT_ID=
